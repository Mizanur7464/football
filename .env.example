# Copy to .env and fill in your values. Do not commit .env.

# From https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# First login on server (optional if you upload .session file)
TELEGRAM_PHONE=+447...
# TELEGRAM_2FA=your_2fa_password_if_enabled

TELEGRAM_SESSION_NAME=relay_session

# Optional. If set, overrides config.yaml relay.source_chat_ids completely.
# Use commas for multiple bots, e.g. 8458387397,888380215
# Comment out or delete to use only config.yaml.
# SOURCE_CHAT_IDS=123456789,987654321

# Target group/channel id
TARGET_CHAT_ID=-1002222222222

# Optional: numeric chat id where /status /relay_on /relay_off work
# CONTROL_CHAT_ID=123456789
